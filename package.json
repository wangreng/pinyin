{
  "name": "pinyin-converter",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx api/dev-server.ts",
    "build": "vite build && esbuild api/boot.ts --platform=node --bundle --format=esm --outdir=dist --banner:js=\"import { createRequire } from 'module';const require = createRequire(import.meta.url);\"",
    "start": "node dist/boot.js",
    "check": "tsc -b",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "format": "prettier --write .",
    "test": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@tanstack/react-query": "^5.66.0",
    "@trpc/client": "^11.0.0-rc.730",
    "@trpc/react-query": "^11.0.0-rc.730",
    "@trpc/server": "^11.0.0-rc.730",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.39.1",
    "geist": "^1.7.2",
    "gsap": "^3.12.7",
    "hono": "^4.7.0",
    "lucide-react": "^0.475.0",
    "mysql2": "^3.12.0",
    "pinyin-pro": "^3.26.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.2.0",
    "superjson": "^2.2.2",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.30.4",
    "esbuild": "^0.25.0",
    "eslint": "^9.19.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.2",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.3",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.22.0",
    "vite": "^7.1.0",
    "vitest": "^3.0.0"
  }
}
